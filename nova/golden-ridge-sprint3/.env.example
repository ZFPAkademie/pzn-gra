# ===========================================
# Golden Ridge Apartments - Environment Config
# ===========================================
# Copy this file to .env.local for local development

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Demo Mode (No Database Required)
# ===========================================
# Leave DATABASE_URL empty/commented to use mock data
# Or explicitly enable mock mode:
# USE_MOCK_DATA=true

# Database (OPTIONAL - leave empty for demo mode)
# DATABASE_URL="postgresql://user:password@localhost:5432/goldenridge?schema=public"

# Authentication (OPTIONAL - only needed for admin features)
# AUTH_SECRET="generate-random-secret-min-32-chars"
# AUTH_URL=http://localhost:3000

# ===========================================
# Sprint 3: Payment & Email Configuration
# ===========================================

# Stripe (required for payment flow)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Note: For local testing, use Stripe CLI:
# stripe listen --forward-to localhost:3000/api/v1/webhooks/stripe

# Resend (optional - emails log to console without this)
# Get API key from https://resend.com/api-keys
# RESEND_API_KEY="re_..."

# Email Configuration
EMAIL_FROM="rezervace@goldenridge.cz"
EMAIL_FROM_NAME="Golden Ridge Apartments"
MANAGER_EMAIL="manager@goldenridge.cz"

# ===========================================
# External Services (optional)
# ===========================================
# BOOKING_API_KEY=""
# AIRBNB_API_KEY=""
# WEATHER_API_KEY=""
